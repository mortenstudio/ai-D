# Match studio/.env (project ID + dataset). Add the frontend URL in Sanity Manage → API → CORS origins.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2026-04-01
PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
PUBLIC_BASE_URL=http://localhost:5173

# Optional: Sanity API token with Viewer access for draft preview / visual editing.
SANITY_API_READ_TOKEN=